<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#3E3E3E"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <com.meetup.views.LinedPaperFrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:linedPaperLineSpacing="@dimen/lined_paper_list_line_step"
        app:linedPaperFirstRuleFromTop="@dimen/lined_paper_list_first_rule"
        app:linedPaperMarginFromStart="@dimen/lined_paper_margin_line_x">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/lined_paper_content_inset_start"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/eventTitleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/lined_paper_list_line_step"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:text="@string/event_title"
                android:textColor="@color/text_on_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/eventMetaItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/lined_paper_list_line_step"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                tools:text="2026-03-25 • Ottawa"
                android:textColor="@color/text_on_dark"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/eventRsvpItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/lined_paper_list_line_step"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:text="@string/status_not_joined"
                android:textColor="@color/accent_light_orange"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/tagsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/lined_paper_list_line_step"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/eventTagItem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/tags"
                    android:textColor="@color/accent_orange"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/eventOtherTagsItem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:textColor="#888888"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

    </com.meetup.views.LinedPaperFrameLayout>

</com.google.android.material.card.MaterialCardView>
