<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="10dp"
    android:background="@color/background_dark">

    <TextView
        android:id="@+id/eventTitleItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Event Title"
        android:textColor="@color/text_on_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/eventMetaItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="2026-03-25 • Ottawa"
        android:textColor="@color/text_on_dark"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/eventRsvpItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Status: Not Joined"
        android:textColor="@color/accent_light_orange"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
