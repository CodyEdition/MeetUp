<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.MeetUp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.MeetUp" parent="Base.Theme.MeetUp" />

    <style name="TextAppearance.MeetUp.AlertDialog.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="ThemeOverlay.MeetUp.AlertDialog" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:backgroundTint">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="colorSurface">@color/background_dark</item>
        <item name="colorOnSurface">@color/text_on_dark</item>
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.MeetUp.AlertDialog.Title</item>
    </style>

    <style name="Theme.MeetUp.Auth" parent="Theme.MeetUp">
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorSurface">@color/background_dark</item>
        <item name="colorOnSurface">@color/text_on_dark</item>
        <item name="colorOnSurfaceVariant">@color/accent_light_orange</item>
        <item name="colorOutline">@color/accent_orange</item>
    </style>

    <!-- Banner shape with rounded bottom corners -->
    <style name="BannerShapeAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">24dp</item>
        <item name="cornerSizeBottomRight">24dp</item>
    </style>
</resources>
